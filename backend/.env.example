# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# These three are consumed by the `db` container AND interpolated into
# DATABASE_URL by docker-compose. Change the password before deploying!
POSTGRES_USER=tabfrix
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=tabfrix
# For local (non-Docker) dev point this at your own Postgres instead:
# DATABASE_URL=postgres://tabfrix:change-me@localhost:5432/tabfrix

# ── Upstream crawl source ────────────────────────────────────────────────────
UPSTREAM_API=https://api.widgetify.ir
UPSTREAM_CLIENT_HEADER=widgetify-extension
UPSTREAM_TIMEOUT_MS=15000

# ── Crawl ────────────────────────────────────────────────────────────────────
# The upstream feed is a static full-year dataset (events keyed by month/day),
# so there is NO recurring crawl. This only controls a one-time seed: crawl once
# on boot if the events table is empty. Refresh manually with `npm run crawl`.
CRAWL_ON_START=true

# ── Translation (LLM) ─────────────────────────────────────────────────────────
# en/it translations of event titles + search labels are generated at crawl time
# via an OpenAI-compatible chat-completions API. Leave LLM_API_KEY empty to skip
# translation (data served Persian-only). Works with OpenAI, Gemini (OpenAI-compat
# endpoint), OpenRouter, Groq, or a local server — set base URL + model to match.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_BATCH_SIZE=40
LLM_TIMEOUT_MS=60000

# ── CORS ─────────────────────────────────────────────────────────────────────
# '*' allows any origin, or pass a comma-separated allow-list.
CORS_ORIGIN=*

# ── Deployment ───────────────────────────────────────────────────────────────
# Only used by the bundled nginx + init-letsencrypt.sh (fresh-VPS path):
DOMAIN=tab.frix.me
[email protected]
# Only used by docker-compose.behind-proxy.yml: localhost port the app is
# published on for your existing reverse proxy to forward to.
APP_HOST_PORT=7110
