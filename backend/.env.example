# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# These three are consumed by the `db` container AND interpolated into
# DATABASE_URL by docker-compose. Change the password before deploying!
POSTGRES_USER=tabfrix
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=tabfrix
# For local (non-Docker) dev point this at your own Postgres instead:
# DATABASE_URL=postgres://tabfrix:change-me@localhost:5432/tabfrix

# ── Upstream crawl source ────────────────────────────────────────────────────
UPSTREAM_API=https://api.widgetify.ir
UPSTREAM_CLIENT_HEADER=widgetify-extension
UPSTREAM_TIMEOUT_MS=15000

# ── Crawl schedule ───────────────────────────────────────────────────────────
# Cron (server time). Default: every day at 03:00.
CRAWL_CRON=0 3 * * *
# Run one crawl on boot if the events table is empty.
CRAWL_ON_START=true

# ── CORS ─────────────────────────────────────────────────────────────────────
# '*' allows any origin, or pass a comma-separated allow-list.
CORS_ORIGIN=*

# ── Deployment (used by nginx + init-letsencrypt.sh) ─────────────────────────
DOMAIN=tab.frix.me
[email protected]
