# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# These three are consumed by the `db` container AND interpolated into
# DATABASE_URL by docker-compose. Change the password before deploying!
POSTGRES_USER=tabfrix
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=tabfrix
# For local (non-Docker) dev point this at your own Postgres instead:
# DATABASE_URL=postgres://tabfrix:change-me@localhost:5432/tabfrix

# ── Upstream crawl source ────────────────────────────────────────────────────
UPSTREAM_API=https://api.widgetify.ir
UPSTREAM_CLIENT_HEADER=widgetify-extension
UPSTREAM_TIMEOUT_MS=15000

# ── Crawl ────────────────────────────────────────────────────────────────────
# The upstream feed is a static full-year dataset (events keyed by month/day),
# so there is NO recurring crawl. This only controls a one-time seed: crawl once
# on boot if the events table is empty. Refresh manually with `npm run crawl`.
CRAWL_ON_START=true

# ── Telegram login (OIDC) ──────────────────────────────────────────────────────
# In @BotFather → Login Widget: copy the Client ID + Client Secret, and under
# "Redirect URIs" add the backend callback EXACTLY:
#     https://tab.frix.me/auth/telegram/callback     (= PUBLIC_URL + /auth/telegram/callback)
# The extension opens Telegram in a normal popup window; the browser is redirected
# here and the backend finishes the code exchange. AUTH_JWT_SECRET signs the
# session token. Empty client id/secret/jwt = the login endpoints are disabled.
TELEGRAM_CLIENT_ID=
TELEGRAM_CLIENT_SECRET=
AUTH_JWT_SECRET=
AUTH_TOKEN_TTL_SEC=2592000

# Public, externally-reachable base URL of THIS backend (no trailing slash). Used
# to build the Telegram redirect URI above; must match what you register in
# BotFather. Defaults to https://<DOMAIN> if unset.
PUBLIC_URL=https://tab.frix.me

# ── Translation ───────────────────────────────────────────────────────────────
# en/it translations are pre-built and shipped in ./seed (no runtime translation
# service / API key). Load them with `npm run seed`. See README "Translations".

# ── CORS ─────────────────────────────────────────────────────────────────────
# '*' allows any origin, or pass a comma-separated allow-list.
CORS_ORIGIN=*

# ── Deployment ───────────────────────────────────────────────────────────────
# Only used by the bundled nginx + init-letsencrypt.sh (fresh-VPS path):
DOMAIN=tab.frix.me
[email protected]
# Only used by docker-compose.behind-proxy.yml: localhost port the app is
# published on for your existing reverse proxy to forward to.
APP_HOST_PORT=7110
