{
  "name": "tabfrix-events-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted events API for Tab Frix. Crawls the upstream /date/events feed, stores it in PostgreSQL, and serves it at GET /date/events.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "migrate": "node dist/db/migrate.js",
    "migrate:dev": "tsx src/db/migrate.ts",
    "crawl": "node dist/crawler/runOnce.js",
    "crawl:dev": "tsx src/crawler/runOnce.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.2.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
