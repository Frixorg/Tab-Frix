DEV=true
# API base URL the extension talks to.
# Point this at your self-hosted backend (see backend/README.md):
VITE_API=https://tab.frix.me
# Upstream default (use this if you are NOT self-hosting):
# VITE_API=https://api.widgetify.ir

# Telegram OIDC Client ID (from @BotFather -> Login Widget) for the Telegram login button.
VITE_TELEGRAM_CLIENT_ID=

# Google OAuth Client ID for the Google login button. Create a **Web application**
# OAuth client (NOT "Chrome Extension") in Google Cloud Console and add the redirect
# URI https://<extension-id>.chromiumapp.org/google under "Authorized redirect URIs".
VITE_GOOGLE_OAUTH_CLIENT_ID=
